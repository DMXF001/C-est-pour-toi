<body>
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useRef } = React;

    function FileAttente() {
      const [file, setFile] = useState(() => {
        try { return JSON.parse(localStorage.getItem("file")) || []; } catch { return []; }
      });
      const [enCours, setEnCours] = useState(() => {
        try { return JSON.parse(localStorage.getItem("enCours")); } catch { return null; }
      });
      const [compteur, setCompteur] = useState(() => {
        return parseInt(localStorage.getItem("compteur")) || 1;
      });
      const [nom, setNom] = useState("");
      const inputRef = useRef(null);

      function save(newFile, newEnCours, newCompteur) {
        localStorage.setItem("file", JSON.stringify(newFile));
        localStorage.setItem("enCours", JSON.stringify(newEnCours));
        localStorage.setItem("compteur", newCompteur);
      }

      function ajouter() {
        if (nom.trim() === "") return;
        const numero = "A" + String(compteur).padStart(3, "0");
        const newFile = [...file, { numero, nom: nom.trim().toUpperCase() }];
        const newCompteur = compteur + 1;
        setFile(newFile);
        setCompteur(newCompteur);
        setNom("");
        save(newFile, enCours, newCompteur);
        inputRef.current?.focus();
      }

      function suivant() {
        let newEnCours = null;
        let newFile = file;
        if (file.length > 0) {
          newEnCours = file[0];
          newFile = file.slice(1);
        }
        setEnCours(newEnCours);
        setFile(newFile);
        save(newFile, newEnCours, compteur);
      }

      function handleKey(e) {
        if (e.key === "Enter") ajouter();
      }

      return (
        <div className="app">
          <div className="header">
            <h1>File d'attente</h1>
            <div className="subtitle">Système de gestion des tickets</div>
          </div>

