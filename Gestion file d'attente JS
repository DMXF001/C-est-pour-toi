            {file.length === 0 ? (
              <div className="liste-vide">File vide</div>
            ) : (
              file.map((p, i) => (
                <div className={`ticket-item${i === 0 ? " first" : ""}`} key={p.numero}>
                  <span className="ticket-num">{p.numero}</span>
                  <span className="ticket-nom">{p.nom}</span>
                  <span className="ticket-position">#{i + 1}</span>
                </div>
              ))
            )}
          </div>
        </div>
      );
    }

    ReactDOM.createRoot(document.getElementById("root")).render(<FileAttente />);
  </script>
