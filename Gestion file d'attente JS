            <div className="encours-label">▶ En cours de service</div>
            {enCours ? (
              <>
                <div className="encours-numero">{enCours.numero}</div>
                <div className="encours-nom">{enCours.nom}</div>
              </>
            ) : (
              <div className="encours-vide">— Aucun ticket —</div>
            )}
          </div>

          <div className="input-row">
            <input
              ref={inputRef}
              type="text"
              placeholder="Entrer un nom..."
              value={nom}
              onChange={e => setNom(e.target.value)}
              onKeyDown={handleKey}
            />
            <button className="btn-ajouter" onClick={ajouter}>+ Ajouter</button>
          </div>

          <button className="btn-suivant" onClick={suivant}>
            Appeler le suivant <span className="arrow">→</span>
          </button>

          <div className="separator"></div>

          <div>
            <div className="liste-header">
              <span className="liste-title">En attente</span>
              <span className="badge">{file.length} personne{file.length !== 1 ? "s" : ""}</span>
