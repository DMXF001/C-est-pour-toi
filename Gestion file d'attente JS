export default function FileAttente() {
  const [file, setFile] = useState([]);
  const [enCours, setEnCours] = useState(null);
  const [compteur, setCompteur] = useState(1);
  const [nom, setNom] = useState("");
  const inputRef = useRef(null);

  function ajouter() {
    if (nom.trim() === "") return;
    const numero = "A" + String(compteur).padStart(3, "0");
    setFile(prev => [...prev, { numero, nom: nom.trim().toUpperCase() }]);
    setCompteur(c => c + 1);
    setNom("");
    inputRef.current?.focus();
  }

  function suivant() {
    if (file.length === 0) {
      setEnCours(null);
    } else {
      setEnCours(file[0]);
      setFile(prev => prev.slice(1));
    }
  }

  function handleKey(e) {
    if (e.key === "Enter") ajouter();
  }

  return (
    <>
      <style>{style}</style>
      <div className="app">
        <div className="header">
          <h1>File d'attente</h1>
          <div className="subtitle">Système de gestion des tickets</div>
        </div>

        {/* En cours */}
        <div className="encours-card">
          <div className="encours-label">▶ En cours de service</div>
          {enCours ? (
            <>
              <div className="encours-numero">{enCours.numero}</div>
              <div className="encours-nom">{enCours.nom}</div>
            </>
          ) : (
            <div className="encours-vide">-- Aucun ticket --</div>
          )}
        </div>

        {/* Input */}
        <div className="input-row">
          <input
            ref={inputRef}
            type="text"
            placeholder="Entrer un nom..."
            value={nom}
            onChange={e => setNom(e.target.value)}
            onKeyDown={handleKey}
          />
          <button className="btn-ajouter" onClick={ajouter}>
            + Ajouter
          </button>
        </div>

        {/* Suivant */}
        <button className="btn-suivant" onClick={suivant}>
          Appeler le suivant <span className="arrow">→</span>
        </button>

        <div className="separator" />

        {/* Liste */}
        <div className="liste-section">
          <div className="liste-header">
            <span className="liste-title">En attente</span>
            <span className="badge">{file.length} personne{file.length !== 1 ? "s" : ""}</span>
          </div>

          {file.length === 0 ? (
            <div className="liste-vide">File vide</div>
          ) : (
            file.map((p, i) => (
              <div className="ticket-item" key={p.numero}>
                <span className="ticket-num">{p.numero}</span>
                <span className="ticket-nom">{p.nom}</span>
                <span className="ticket-position">#{i + 1}</span>
              </div>
            ))
          )}
        </div>
      </div>
    </>
  );
}
